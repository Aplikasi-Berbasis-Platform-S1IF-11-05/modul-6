<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Toko Pak Cik & Aimar</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700;800&family=Space+Grotesk:wght@500;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <style>
        :root {
            --fresh-900: #173625;
            --fresh-700: #2f6a3b;
            --fresh-500: #4f9d4e;
            --fresh-300: #8ccf80;
            --accent-500: #ff9f43;
            --accent-300: #ffd092;
            --text-main: #1d2d25;
            --text-soft: #5d6d64;
            --surface: rgba(255, 255, 255, 0.86);
            --surface-solid: #ffffff;
            --border-soft: rgba(43, 96, 55, 0.14);
            --shadow-soft: 0 20px 40px rgba(23, 54, 37, 0.14);
        }

        * {
            box-sizing: border-box;
        }

        body {
            margin: 0;
            font-family: "Outfit", sans-serif;
            color: var(--text-main);
            background:
                radial-gradient(circle at 15% 15%, rgba(140, 207, 128, 0.35), transparent 45%),
                radial-gradient(circle at 85% 12%, rgba(255, 159, 67, 0.20), transparent 40%),
                linear-gradient(160deg, #f4fdea 0%, #eff8ff 55%, #fffaf0 100%);
            min-height: 100vh;
            position: relative;
        }

        body::before {
            content: "";
            position: fixed;
            inset: 0;
            pointer-events: none;
            background-image:
                linear-gradient(rgba(47, 106, 59, 0.06) 1px, transparent 1px),
                linear-gradient(90deg, rgba(47, 106, 59, 0.06) 1px, transparent 1px);
            background-size: 26px 26px;
            mask-image: radial-gradient(circle at center, black 35%, transparent 85%);
            z-index: 0;
        }

        .page-wrap {
            position: relative;
            z-index: 1;
            padding-top: 1.5rem;
        }

        .nav-glass {
            border-radius: 18px;
            background: var(--surface);
            border: 1px solid var(--border-soft);
            backdrop-filter: blur(10px);
            box-shadow: var(--shadow-soft);
            margin-bottom: 1rem;
        }

        .nav-brand {
            font-family: "Space Grotesk", sans-serif;
            color: var(--fresh-900);
            font-weight: 700;
            display: flex;
            align-items: center;
        }

        .nav-pill {
            border-radius: 999px;
            background: rgba(79, 157, 78, 0.15);
            color: var(--fresh-700);
            font-size: 0.78rem;
            font-weight: 700;
            padding: 0.35rem 0.65rem;
        }

        .hero-shell {
            margin-bottom: 1.5rem;
        }

        .hero-grid {
            display: grid;
            grid-template-columns: 1.4fr 1fr;
            gap: 1rem;
        }

        .hero-copy,
        .hero-highlight {
            border-radius: 28px;
            background: var(--surface);
            border: 1px solid var(--border-soft);
            backdrop-filter: blur(10px);
            box-shadow: var(--shadow-soft);
            padding: 1.5rem;
            animation: riseIn 0.7s ease both;
        }

        .hero-copy {
            animation-delay: 0.06s;
        }

        .hero-highlight {
            animation-delay: 0.14s;
        }

        .eyebrow {
            margin: 0;
            letter-spacing: 0.08em;
            font-size: 0.75rem;
            font-weight: 700;
            color: var(--fresh-700);
            text-transform: uppercase;
        }

        .hero-copy h1 {
            margin-top: 0.55rem;
            margin-bottom: 0.75rem;
            font-family: "Space Grotesk", sans-serif;
            font-size: clamp(1.6rem, 2.4vw, 2.45rem);
            line-height: 1.15;
        }

        .hero-subtitle {
            margin: 0;
            color: var(--text-soft);
            max-width: 52ch;
        }

        .hero-actions {
            margin-top: 1.2rem;
            display: flex;
            gap: 0.7rem;
            align-items: center;
            flex-wrap: wrap;
        }

        .btn-fresh {
            background: linear-gradient(145deg, var(--fresh-700), var(--fresh-500));
            border: none;
            color: #fff;
            border-radius: 14px;
            padding: 0.72rem 1rem;
            font-weight: 700;
            box-shadow: 0 12px 24px rgba(47, 106, 59, 0.26);
        }

        .btn-fresh:hover {
            background: linear-gradient(145deg, #275f34, #478f48);
            color: #fff;
        }

        .search-shell {
            flex: 1;
            min-width: 250px;
            background: #fff;
            border: 1px solid var(--border-soft);
            border-radius: 14px;
            overflow: hidden;
        }

        .search-shell .input-group-text {
            border: none;
            background: transparent;
            color: var(--fresh-700);
            padding-right: 0.2rem;
        }

        .search-shell i {
            color: var(--fresh-700);
        }

        .search-shell input {
            border: none;
            outline: none;
            width: 100%;
            color: var(--text-main);
            font-size: 0.95rem;
            background: transparent;
            box-shadow: none;
            padding-left: 0.25rem;
        }

        .highlight-label {
            margin: 0;
            color: var(--text-soft);
            font-size: 0.86rem;
            text-transform: uppercase;
            letter-spacing: 0.07em;
            font-weight: 700;
        }

        .hero-highlight h3 {
            margin-top: 0.55rem;
            margin-bottom: 0.85rem;
            font-family: "Space Grotesk", sans-serif;
            font-size: 1.15rem;
        }

        .mini-bars {
            display: flex;
            gap: 0.35rem;
            height: 70px;
            margin-bottom: 0.8rem;
            align-items: flex-end;
        }

        .mini-bars span {
            flex: 1;
            height: var(--h);
            border-radius: 8px 8px 4px 4px;
            background: linear-gradient(180deg, var(--accent-300), var(--accent-500));
        }

        .highlight-note {
            margin: 0;
            font-size: 0.9rem;
            color: var(--text-soft);
        }

        .stats-grid {
            margin-top: 1rem;
            display: grid;
            grid-template-columns: repeat(3, minmax(0, 1fr));
            gap: 0.8rem;
        }

        .stat-card {
            border-radius: 18px;
            background: var(--surface-solid);
            border: 1px solid var(--border-soft);
            box-shadow: var(--shadow-soft);
            padding: 0;
            animation: riseIn 0.8s ease both;
        }

        .stat-card .card-body {
            padding: 1rem 1.1rem;
            display: flex;
            gap: 0.85rem;
            align-items: center;
        }

        .stat-card:nth-child(2) {
            animation-delay: 0.1s;
        }

        .stat-card:nth-child(3) {
            animation-delay: 0.18s;
        }

        .stat-icon {
            width: 44px;
            height: 44px;
            border-radius: 12px;
            display: grid;
            place-items: center;
            color: #fff;
            font-size: 1.2rem;
            background: linear-gradient(140deg, var(--fresh-700), var(--fresh-500));
        }

        .stat-copy small {
            display: block;
            color: var(--text-soft);
            font-size: 0.8rem;
            letter-spacing: 0.04em;
            text-transform: uppercase;
            margin-bottom: 0.2rem;
        }

        .stat-copy strong {
            font-family: "Space Grotesk", sans-serif;
            font-size: 1.12rem;
        }

        .section-head {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 0.7rem;
            margin-bottom: 1rem;
            animation: riseIn 0.8s ease both;
            animation-delay: 0.22s;
        }

        .section-head h2 {
            margin: 0;
            font-size: 1.4rem;
            font-family: "Space Grotesk", sans-serif;
        }

        .section-head p {
            margin: 0.2rem 0 0;
            color: var(--text-soft);
        }

        .btn-outline-clear {
            border-radius: 999px;
            border: 1px solid var(--border-soft);
            background: rgba(255, 255, 255, 0.7);
            color: var(--fresh-700);
            font-weight: 600;
            padding: 0.55rem 0.9rem;
        }

        .products-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(235px, 1fr));
            gap: 0.9rem;
        }

        .product-card {
            border-radius: 18px;
            background: var(--surface-solid);
            border: 1px solid var(--border-soft);
            box-shadow: var(--shadow-soft);
            padding: 0;
            min-height: 100%;
            overflow: hidden;
            animation: cardIn 0.55s cubic-bezier(0.2, 0.85, 0.25, 1) both;
            animation-delay: calc(var(--stagger) * 70ms);
        }

        .product-card .card-body {
            padding: 1rem;
            display: flex;
            flex-direction: column;
            height: 100%;
        }

        .product-title {
            margin: 0;
            font-size: 1.07rem;
            font-weight: 700;
        }

        .price-tag {
            margin: 0.5rem 0;
            font-size: 1.23rem;
            font-family: "Space Grotesk", sans-serif;
            color: var(--fresh-700);
        }

        .product-meta {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 0.9rem;
        }

        .stock-chip {
            font-size: 0.78rem;
            padding: 0.28rem 0.62rem;
            font-weight: 700;
            letter-spacing: 0.03em;
            border: none;
        }

        .stock-ok {
            background: rgba(79, 157, 78, 0.15);
            color: var(--fresh-700);
        }

        .stock-low {
            background: rgba(255, 159, 67, 0.2);
            color: #9a5100;
        }

        .item-code {
            color: var(--text-soft);
            font-size: 0.83rem;
        }

        .product-actions {
            display: flex;
            gap: 0.55rem;
        }

        .btn-card {
            border-radius: 10px;
            padding: 0.52rem 0.65rem;
            font-size: 0.88rem;
            font-weight: 700;
        }

        .product-actions .btn {
            flex: 1;
        }

        .btn-edit {
            background: rgba(79, 157, 78, 0.16);
            color: var(--fresh-700);
        }

        .btn-delete {
            background: rgba(255, 159, 67, 0.18);
            color: #8a4600;
        }

        .empty-state {
            background: rgba(255, 255, 255, 0.82);
            border: 1px dashed rgba(47, 106, 59, 0.35);
            border-radius: 20px;
            padding: 2rem 1rem;
            text-align: center;
            color: var(--text-soft);
            animation: riseIn 0.5s ease both;
        }

        .empty-state i {
            display: block;
            font-size: 2rem;
            color: var(--fresh-500);
            margin-bottom: 0.6rem;
        }

        .modal-glass {
            border: 1px solid var(--border-soft);
            border-radius: 18px;
            box-shadow: var(--shadow-soft);
        }

        .modal-title {
            font-family: "Space Grotesk", sans-serif;
        }

        .modal-subtitle {
            font-size: 0.88rem;
            color: var(--text-soft);
            margin-top: 0.2rem;
        }

        .form-label {
            font-size: 0.84rem;
            font-weight: 700;
            color: var(--text-soft);
            text-transform: uppercase;
            letter-spacing: 0.04em;
        }

        .form-control {
            border-radius: 10px;
            border-color: rgba(47, 106, 59, 0.2);
            padding: 0.64rem 0.75rem;
        }

        .form-control:focus {
            border-color: var(--fresh-500);
            box-shadow: 0 0 0 0.2rem rgba(79, 157, 78, 0.2);
        }

        .toast {
            border-radius: 12px;
        }

        @keyframes riseIn {
            from {
                opacity: 0;
                transform: translateY(12px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        @keyframes cardIn {
            from {
                opacity: 0;
                transform: translateY(20px) scale(0.98);
            }
            to {
                opacity: 1;
                transform: translateY(0) scale(1);
            }
        }

        @media (max-width: 992px) {
            .hero-grid {
                grid-template-columns: 1fr;
            }

            .stats-grid {
                grid-template-columns: 1fr;
            }
        }

        @media (max-width: 575px) {
            .hero-copy,
            .hero-highlight,
            .stat-card,
            .product-card {
                border-radius: 16px;
            }

            .hero-actions {
                align-items: stretch;
            }

            .btn-fresh,
            .search-shell {
                width: 100%;
            }

            .nav-pill {
                display: none;
            }

            .section-head {
                flex-direction: column;
                align-items: flex-start;
            }

            .btn-outline-clear {
                width: 100%;
            }
        }
    </style>
</head>
<body>
<div class="page-wrap">
    <nav class="navbar navbar-expand-lg container-xl nav-glass px-3">
        <div class="container-fluid px-0">
            <span class="navbar-brand nav-brand mb-0 h1">
                <i class="bi bi-shop me-2"></i> Pak Cik Mart
            </span>
            <span class="nav-pill">
                <i class=""></i> Online
            </span>
        </div>
    </nav>

    <section class="container-xl hero-shell">
        <div class="row g-3">
            <div class="col-lg-8">
                <div class="hero-copy h-100">
                    <p class="eyebrow">TOKO KELONTONG PAK CIK JIRR</p>
                    <h1>Selamat datang di kelontong kami</h1>
                    <p class="hero-subtitle">
                        Kelola inventori dengan mudah dan efisien. Tambahkan, perbarui, atau hapus produk sesuai kebutuhan toko Anda. Pantau stok dan nilai inventori secara real-time untuk memastikan bisnis tetap berjalan lancar.
                    </p>
                    <div class="hero-actions">
                        <button class="btn btn-fresh" onclick="openModal()">
                            <i class="bi bi-plus-circle me-1"></i> Tambah Produk
                        </button>
                        <div class="input-group search-shell">
                            <span class="input-group-text">
                                <i class="bi bi-search"></i>
                            </span>
                            <input type="text" id="searchInput" class="form-control" placeholder="Cari nama produk...">
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-4">
                <aside class="hero-highlight h-100">
                    <p class="highlight-label">Trend Hari Ini</p>
                    <h3 id="highlightProduct">Menunggu data produk...</h3>
                    <div class="mini-bars">
                        <span style="--h:72%"></span>
                        <span style="--h:48%"></span>
                        <span style="--h:90%"></span>
                        <span style="--h:58%"></span>
                        <span style="--h:76%"></span>
                    </div>
                    <p class="highlight-note">Produk dengan stok tertinggi otomatis muncul di panel ini.</p>
                </aside>
            </div>
        </div>

        <div class="row g-3 mt-1">
            <div class="col-md-4">
                <article class="stat-card card h-100 border-0">
                    <div class="card-body">
                        <div class="stat-icon"><i class="bi bi-grid"></i></div>
                        <div class="stat-copy">
                            <small>Total Produk</small>
                            <strong id="statProducts">0</strong>
                        </div>
                    </div>
                </article>
            </div>
            <div class="col-md-4">
                <article class="stat-card card h-100 border-0">
                    <div class="card-body">
                        <div class="stat-icon"><i class="bi bi-box-seam"></i></div>
                        <div class="stat-copy">
                            <small>Total Stok</small>
                            <strong id="statStock">0 pcs</strong>
                        </div>
                    </div>
                </article>
            </div>
            <div class="col-md-4">
                <article class="stat-card card h-100 border-0">
                    <div class="card-body">
                        <div class="stat-icon"><i class="bi bi-cash-stack"></i></div>
                        <div class="stat-copy">
                            <small>Estimasi Nilai</small>
                            <strong id="statValue">Rp 0</strong>
                        </div>
                    </div>
                </article>
            </div>
        </div>
    </section>

    <main class="container-xl pb-4">
        <div class="section-head">
            <div>
                <h2>Etalase Inventori</h2>
                <p id="resultMeta">0 produk siap dijual</p>
            </div>
            <button id="clearSearchBtn" class="btn btn-outline-clear">Reset Pencarian</button>
        </div>

        <section id="productGrid" class="row g-3"></section>
    </main>
</div>

<div class="modal fade" id="formModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content modal-glass">
            <div class="modal-header border-0 pb-0">
                <div>
                    <h5 class="modal-title" id="modalTitle">Tambah Produk Baru</h5>
                    <p class="modal-subtitle mb-0" id="modalSubtitle">Isi data produk untuk inventori toko.</p>
                </div>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form id="productForm">
                <div class="modal-body pt-3">
                    <input type="hidden" id="prodId">

                    <div class="mb-3">
                        <label class="form-label" for="prodName">Nama Produk</label>
                        <input type="text" class="form-control" id="prodName" placeholder="Contoh: Beras Premium 5kg" required>
                    </div>

                    <div class="mb-3">
                        <label class="form-label" for="prodPrice">Harga (Rp)</label>
                        <input type="number" min="0" class="form-control" id="prodPrice" placeholder="Contoh: 65000" required>
                    </div>

                    <div>
                        <label class="form-label" for="prodStock">Jumlah Stok</label>
                        <input type="number" min="0" class="form-control" id="prodStock" placeholder="Contoh: 24" required>
                    </div>
                </div>
                <div class="modal-footer border-0 pt-1">
                    <button type="submit" class="btn btn-fresh w-100">Simpan Produk</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="deleteModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content modal-glass">
            <div class="modal-header border-0">
                <h5 class="modal-title">Hapus Produk</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body pt-0">
                <p class="mb-1">Data ini akan dihapus dari inventori.</p>
                <p class="text-muted mb-0" id="deleteInfo">Pilih produk yang ingin dihapus.</p>
            </div>
            <div class="modal-footer border-0">
                <button type="button" class="btn btn-light" data-bs-dismiss="modal">Batal</button>
                <button type="button" class="btn btn-danger" id="confirmDeleteBtn">Ya, Hapus</button>
            </div>
        </div>
    </div>
</div>

<div class="toast-container position-fixed top-0 end-0 p-3">
    <div id="appToast" class="toast align-items-center text-bg-success border-0" role="alert" aria-live="assertive" aria-atomic="true">
        <div class="d-flex">
            <div class="toast-body" id="toastMessage">Aksi berhasil.</div>
            <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
    const appState = {
        products: [],
        deleteTargetId: null
    };

    const productModal = new bootstrap.Modal(document.getElementById('formModal'));
    const deleteModal = new bootstrap.Modal(document.getElementById('deleteModal'));

    function toNumber(value) {
        const number = Number(value);
        return Number.isFinite(number) ? number : 0;
    }

    function formatCurrency(value) {
        return new Intl.NumberFormat('id-ID', {
            style: 'currency',
            currency: 'IDR',
            maximumFractionDigits: 0
        }).format(toNumber(value));
    }

    function escapeHtml(text) {
        return String(text)
            .replace(/&/g, '&amp;')
            .replace(/</g, '&lt;')
            .replace(/>/g, '&gt;')
            .replace(/"/g, '&quot;')
            .replace(/'/g, '&#39;');
    }

    function showToast(message, type) {
        const toastEl = document.getElementById('appToast');
        const variantClass = {
            success: 'text-bg-success',
            danger: 'text-bg-danger',
            warning: 'text-bg-warning',
            info: 'text-bg-info'
        };

        toastEl.classList.remove('text-bg-success', 'text-bg-danger', 'text-bg-warning', 'text-bg-info');
        toastEl.classList.add(variantClass[type] || 'text-bg-success');
        $('#toastMessage').text(message);
        bootstrap.Toast.getOrCreateInstance(toastEl, { delay: 2400 }).show();
    }

    function renderStats(products) {
        const totalProducts = products.length;
        const totalStock = products.reduce((sum, p) => sum + toNumber(p.stock), 0);
        const totalValue = products.reduce((sum, p) => sum + (toNumber(p.price) * toNumber(p.stock)), 0);

        $('#statProducts').text(totalProducts.toLocaleString('id-ID'));
        $('#statStock').text(`${totalStock.toLocaleString('id-ID')} pcs`);
        $('#statValue').text(formatCurrency(totalValue));
    }

    function renderHighlight(products) {
        if (!products.length) {
            $('#highlightProduct').text('Belum ada produk di inventori.');
            return;
        }

        const topStock = [...products].sort((a, b) => toNumber(b.stock) - toNumber(a.stock))[0];
        $('#highlightProduct').text(`${topStock.name} - stok ${toNumber(topStock.stock)} pcs`);
    }

    function renderMeta(totalFiltered, keyword) {
        const suffix = keyword ? ` untuk kata kunci "${keyword}"` : '';
        $('#resultMeta').text(`${totalFiltered} produk siap dijual${suffix}`);
    }

    function renderProducts(products) {
        if (!products.length) {
            $('#productGrid').html(`
                <div class="col-12">
                    <div class="empty-state">
                        <i class="bi bi-bag-heart"></i>
                        <h5 class="mb-1">Produk belum ditemukan</h5>
                        <p class="mb-0">Coba ubah kata kunci pencarian atau tambahkan produk baru.</p>
                    </div>
                </div>
            `);
            return;
        }

        const cards = products.map((product, index) => {
            const stock = toNumber(product.stock);
            const stockClass = stock <= 5 ? 'stock-low' : 'stock-ok';
            const stockText = stock <= 5 ? 'Stok Menipis' : 'Stok Aman';

            return `
                <div class="col-sm-6 col-xl-4">
                    <article class="product-card card h-100 border-0" style="--stagger: ${index};">
                        <div class="card-body">
                            <div>
                                <p class="item-code mb-2">SKU ${toNumber(product.id)}</p>
                                <h3 class="product-title">${escapeHtml(product.name)}</h3>
                                <p class="price-tag">${formatCurrency(product.price)}</p>
                                <div class="product-meta">
                                    <span class="stock-chip badge rounded-pill ${stockClass}">${stockText}</span>
                                    <strong>${stock} pcs</strong>
                                </div>
                            </div>
                            <div class="product-actions mt-auto">
                                <button class="btn btn-sm btn-card btn-edit js-edit" data-id="${toNumber(product.id)}">
                                    <i class="bi bi-pencil-square me-1"></i> Edit
                                </button>
                                <button class="btn btn-sm btn-card btn-delete js-delete" data-id="${toNumber(product.id)}">
                                    <i class="bi bi-trash3 me-1"></i> Hapus
                                </button>
                            </div>
                        </div>
                    </article>
                </div>
            `;
        }).join('');

        $('#productGrid').html(cards);
    }

    function renderDashboard() {
        const keyword = $('#searchInput').val().trim().toLowerCase();
        const filtered = appState.products.filter((product) => {
            return String(product.name || '').toLowerCase().includes(keyword);
        });

        renderStats(appState.products);
        renderHighlight(appState.products);
        renderMeta(filtered.length, keyword);
        renderProducts(filtered);
    }

    function loadData() {
        $.get('/api/products')
            .done((data) => {
                appState.products = Array.isArray(data) ? data : [];
                renderDashboard();
            })
            .fail(() => {
                showToast('Gagal memuat data produk.', 'danger');
            });
    }

    function openModal() {
        $('#productForm')[0].reset();
        $('#prodId').val('');
        $('#modalTitle').text('Tambah Produk Baru');
        $('#modalSubtitle').text('Isi data produk untuk inventori toko.');
        productModal.show();
    }

    window.openModal = openModal;

    function fillModalByProduct(product) {
        $('#prodId').val(product.id);
        $('#prodName').val(product.name);
        $('#prodPrice').val(toNumber(product.price));
        $('#prodStock').val(toNumber(product.stock));
        $('#modalTitle').text('Edit Produk');
        $('#modalSubtitle').text('Perbarui informasi produk agar stok tetap akurat.');
        productModal.show();
    }

    $('#productForm').on('submit', function(event) {
        event.preventDefault();

        const id = $('#prodId').val();
        const payload = {
            name: $('#prodName').val().trim(),
            price: toNumber($('#prodPrice').val()),
            stock: toNumber($('#prodStock').val())
        };

        if (!payload.name) {
            showToast('Nama produk wajib diisi.', 'warning');
            return;
        }

        const method = id ? 'PUT' : 'POST';
        const url = id ? `/api/products/${id}` : '/api/products';

        $.ajax({
            url,
            method,
            contentType: 'application/json',
            data: JSON.stringify(payload)
        })
            .done(() => {
                productModal.hide();
                loadData();
                showToast(id ? 'Produk berhasil diperbarui.' : 'Produk berhasil ditambahkan.', 'success');
            })
            .fail(() => {
                showToast('Gagal menyimpan data produk.', 'danger');
            });
    });

    $(document).on('click', '.js-edit', function() {
        const id = toNumber($(this).data('id'));
        const product = appState.products.find((item) => toNumber(item.id) === id);
        if (product) {
            fillModalByProduct(product);
        }
    });

    $(document).on('click', '.js-delete', function() {
        const id = toNumber($(this).data('id'));
        appState.deleteTargetId = id;
        const product = appState.products.find((item) => toNumber(item.id) === id);
        $('#deleteInfo').text(product ? `Produk: ${product.name}` : 'Produk ini akan dihapus permanen.');
        deleteModal.show();
    });

    $('#confirmDeleteBtn').on('click', function() {
        if (!appState.deleteTargetId) {
            return;
        }

        $.ajax({
            url: `/api/products/${appState.deleteTargetId}`,
            method: 'DELETE'
        })
            .done(() => {
                deleteModal.hide();
                loadData();
                showToast('Produk berhasil dihapus.', 'success');
            })
            .fail(() => {
                showToast('Gagal menghapus produk.', 'danger');
            });
    });

    $('#searchInput').on('input', function() {
        renderDashboard();
    });

    $('#clearSearchBtn').on('click', function() {
        $('#searchInput').val('');
        renderDashboard();
        $('#searchInput').trigger('focus');
    });

    $(document).ready(function() {
        loadData();
    });
</script>
</body>
</html>